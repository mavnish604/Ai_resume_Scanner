%%{init: {'theme': 'dark'}}%%
flowchart TD
    %% Title
    classDef title fill:none,stroke:none,font-size:20px,font-weight:bold;
    Title["Level 2 Data Flow Diagram - Process 3.0 Evaluate Resume Details"]:::title

    %% External Entities & Stores
    User["User"]
    D1[("Temporary File<br/>System")]
    LLM_APIs["LLM Inference APIs<br/>Groq, HF, Sarvam"]

    %% Level 2 Processes
    P31(("3.1<br/>Extract Text<br/>From PDF"))
    P32(("3.2<br/>Convert PDF<br/>to Base64 Image"))
    P33(("3.3<br/>Calculate<br/>Semantic Score"))
    P34(("3.4<br/>Evaluate Visual<br/>Structure"))
    P35(("3.5<br/>Multi-Model<br/>Ensemble Review"))
    P36(("3.6<br/>Aggregate<br/>Final Weighted Score"))

    %% Data Flows
    User -- "Job Description" --> P33
    User -- "Job Description" --> P35

    D1 -- "PDF Path" --> P31
    D1 -- "PDF Path" --> P32

    P31 -- "Raw Resume Text" --> P33
    P31 -- "Raw Resume Text" --> P35

    P32 -- "Base64 Image String" --> P34

    P33 -- "Cosine Similarity Score (10%)" --> P36

    P34 -- "Resume Image + Prompt" --> LLM_APIs
    LLM_APIs -- "Structure JSON (Score, Feedback)" --> P34
    P34 -- "Structure Result (20%)" --> P36

    P35 -- "Text + JD Prompts" --> LLM_APIs
    LLM_APIs -- "3x Individual Reviews" --> P35
    P35 -- "Summary Trigger (Indus)" --> LLM_APIs
    LLM_APIs -- "Final Sub-Summary" --> P35
    P35 -- "Ensemble Avg Score (70%) + All Feedback" --> P36

    P36 -- "Aggregated JSON Payload Display" --> User
